
#include<stdio.h>
#include<stdlib.h>
#include<string.h>
struct Node
{
    int id;
    char username[30];
    char name[50];
    struct Node *left;
    struct Node *right;
};
struct Node *root=NULL;
void insert()
{
    struct Node *newnode;
    newnode=(struct Node*)malloc(sizeof(struct Node));
    printf("Enter Unique ID (number): ");
    scanf("%d",&newnode->id);
    printf("Enter Username (no spaces): ");
    scanf("%s",newnode->username);
    printf("Enter Display Name: ");
    scanf(" %[^\n]",newnode->name);
    newnode->left=NULL;
    newnode->right=NULL;
    if(root==NULL)
        root=newnode;
    else
    {
        struct Node *temp=root,*pre=NULL;
        while(temp!=NULL)
        {
            pre=temp;
            if(strcmp(newnode->username,temp->username)<=0)
                temp=temp->left;
            else
                temp=temp->right;
        }
        if(strcmp(newnode->username,pre->username)<=0)
            pre->left=newnode;
        else
            pre->right=newnode;
    }
    printf("Friend added (if username was unique).\n");
}
void inorder(struct Node *temp)
{
    if(temp==NULL)
        return;
    inorder(temp->left);
    printf("ID: %d   Username: %-10s   Name: %s\n",
    temp->id,temp->username,temp->name);
    inorder(temp->right);
}
void search()
{
    struct Node *temp=root;
    char key[30];
    int flag=0;
    printf("Enter Username to Search: ");
    scanf("%s",key);
    while(temp!=NULL)
    {
        int cmp=strcmp(key,temp->username);
        if(cmp==0)
        {
            printf("Friend Found:\n");
            printf("ID      : %d\n",temp->id);
            printf("Username: %s\n",temp->username);
            printf("Name    : %s\n",temp->name);
            flag=1;
            break;
        }
        else if(cmp<0)
            temp=temp->left;
        else
            temp=temp->right;
    }
    if(flag==0)
        printf("Friend not found\n");
}
int main()
{
    int choice;
    while(1)
    {
        printf("\n1. Add Friend\n");
        printf("2. Search Friend\n");
        printf("3. Display Friend List\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d",&ch);
        switch(ch)
        {
            case 1: insert(); break;
            case 2: search(); break;
            case 3:
                printf("\nFriend List (Sorted by Username):\n");
                printf("----------------------------------\n");
                inorder(root);
                break;
            case 4:
                printf("Exiting...\n");
                return 0;
            default:
                printf("Invalid choice\n");
        }
    }
}
