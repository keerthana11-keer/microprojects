#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#define m 10
struct Node
{
    char name[30];
    char type[20];
    int scope;
    int address;
    struct Node *next;
};
struct Node *table[m];
int count = 0;
int hash(char name[])
{
    int i,sum=0;
    for(i=0;name[i]!='\0';i++)
        sum=sum+name[i];
    return sum % m;
}
void insert()
{
    struct Node *newnode;
    newnode=(struct Node*)malloc(sizeof(struct Node));
    printf("Enter identifier name: ");
    scanf("%s",newnode->name);
    printf("Enter data type: ");
    scanf("%s",newnode->type);
    printf("Enter scope level: ");
    scanf("%d",&newnode->scope);
    printf("Enter memory address: ");
    scanf("%d",&newnode->address);
    newnode->next=NULL;
    int index=hash(newnode->name);
    if(table[index]==NULL)
        table[index]=newnode;
    else
    {
        struct Node *temp=table[index];
        while(temp->next!=NULL)
            temp=temp->next;

        temp->next=newnode;
    }
    count++;
    float load=(float)count/m;
    printf("Load Factor = %.2f\n",load);
    if(load>0.75)
        printf("Load factor exceeded 0.75 (Rehashing suggested)\n");
}
void search()
{
    char key[30];
    printf("Enter identifier to search: ");
    scanf("%s",key);
    int index=hash(key);
    struct Node *temp=table[index];
    while(temp!=NULL)
    {
        if(strcmp(temp->name,key)==0)
        {
            printf("\nSymbol Found\n");
            printf("Identifier: %s\n",temp->name);
            printf("Type: %s\n",temp->type);
            printf("Scope: %d\n",temp->scope);
            printf("Address: %d\n",temp->address);
            return;
        }
        temp=temp->next;
    }
    printf("Symbol not found\n");
}
void deleteSymbol()
{
    char key[30];
    printf("Enter identifier to delete: ");
    scanf("%s",key);
    int index=hash(key);
    struct Node *temp=table[index];
    struct Node *pre=NULL;
    while(temp!=NULL)
    {
        if(strcmp(temp->name,key)==0)
        {
            if(pre==NULL)
                table[index]=temp->next;
            else
                pre->next=temp->next;

            free(temp);
            count--;
            printf("Symbol deleted\n");
            return;
        }
        pre=temp;
        temp=temp->next;
    }
    printf("Symbol not found\n");
}
void display()
{
    int i;
    for(i=0;i<m;i++)
    {
        printf("\nBucket[%d] --> ",i);
        struct Node *temp=table[i];
        while(temp!=NULL)
        {
            printf("(%s,%s,S%d,A%d) -> ",
            temp->name,
            temp->type,
            temp->scope,
            temp->address);
            temp=temp->next;
        }
        printf("NULL");
    }
}
int main()
{
    int i,ch;
    for(i=0;i<m;i++)
        table[i]=NULL;
    while(1)
    {
        printf("\n1.Insert Symbol");
        printf("\n2.Delete Symbol");
        printf("\n3.Search Symbol");
        printf("\n4.Display Symbol Table");
        printf("\n5.Exit");
        printf("\nEnter choice: ");
        scanf("%d",&ch);
        switch(ch)
        {
            case 1: insert(); break;
            case 2: deleteSymbol(); break;
            case 3: search(); break;
            case 4: display(); break;
            case 5: exit(0);
            default: printf("Invalid choice\n");
        }
    }
    return 0;
}
